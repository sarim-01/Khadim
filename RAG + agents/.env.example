# Copy to .env and fill in. For docker-compose, use postgres/redis service names:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgres:5432/restaurant

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/restaurant

REDIS_HOST=localhost
REDIS_PORT=6379

GROQ_API_KEY=
OPENWEATHER_KEY=
ELEVENLABS_API_KEY=

JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

STT_BACKEND=elevenlabs
