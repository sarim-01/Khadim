# Copy to .env and fill in. For docker-compose, use postgres/redis service names:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgres:5432/restaurant

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/restaurant

# Redis: set REDIS_URL (Railway plugin) OR REDIS_HOST + REDIS_PORT (local)
# REDIS_URL=redis://default:password@host:6379
REDIS_HOST=localhost
REDIS_PORT=6379

GROQ_API_KEY=
# Optional second key for admin AI routes (see admin/admin_routes.py)
GROQ_API2_KEY=
OPENWEATHER_KEY=
ELEVENLABS_API_KEY=

JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

STT_BACKEND=elevenlabs
